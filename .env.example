# Public canonical URL of the app (production, post-login). Used to allow Server
# Action origins behind a proxy/custom domain. e.g. https://app.tradenza.dev
NEXT_PUBLIC_APP_URL=https://app.tradenza.dev

# Public URL of the marketing/landing site. The landing page is served only on
# this host; the app host redirects "/" to the dashboard. e.g. https://tradenza.dev
NEXT_PUBLIC_MARKETING_URL=https://tradenza.dev

# Database — Neon PostgreSQL
DATABASE_URL="postgresql://user:password@host/tradenza?sslmode=require"

# Auth — Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Storage — Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tradenza-screenshots
R2_PUBLIC_URL=https://screenshots.tradenza.app

# Market data — Databento
DATABENTO_API_KEY=

# Error monitoring — Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
