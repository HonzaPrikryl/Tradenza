# ── Domains / host-based routing ─────────────────────────────────────────────
#   LOCAL → leave BOTH empty. Everything runs on http://localhost:3000 as a
#           single host and no host-based redirect happens.
# e.g. PROD: NEXT_PUBLIC_APP_URL=https://app.tradenza.dev
NEXT_PUBLIC_APP_URL=
# e.g. PROD: NEXT_PUBLIC_MARKETING_URL=https://tradenza.dev
NEXT_PUBLIC_MARKETING_URL=

# ── Database — Neon PostgreSQL ───────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/tradenza?sslmode=require"

# ── Auth — Clerk ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# ── Storage — Cloudflare R2 (optional: trade screenshots) ────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tradenza-screenshots
R2_PUBLIC_URL=https://screenshots.tradenza.app

# ── Market data — candle charts (all optional) ───────────────────────────────
# Databento powers futures + stocks charts.
DATABENTO_API_KEY=
# US equities dataset. Default XNAS.ITCH (Nasdaq-listed only); set a consolidated
# feed like EQUS.MINI or DBEQ.BASIC for full NYSE + Nasdaq coverage.
DATABENTO_EQUITIES_DATASET=
# Polygon.io powers forex charts (Currencies aggregates).
POLYGON_API_KEY=
# Binance powers crypto charts — no key needed. Override the host only if the
# default market-data endpoint is blocked in your region.
BINANCE_API_BASE=

# ── Error monitoring — Sentry (optional) ─────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Rate limiting — Upstash Redis (optional) ─────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Analytics — PostHog EU (optional, privacy-respecting) ────────────────────
#   Cookieless, EU-hosted. Leave the key empty to disable analytics entirely.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Admin (optional: internal /admin user overview) ──────────────────────────
#   Comma-separated e-mails allowed to access the internal /admin page.
#   Leave empty to disable the admin overview entirely.
ADMIN_EMAILS=

# ── Feedback e-mail — Resend (optional: notify on new feedback) ───────────────
#   All three enable e-mail notifications for user feedback. Feedback is always
#   stored in the DB and visible in /admin/feedback even without these.
RESEND_API_KEY=
FEEDBACK_FROM_EMAIL=feedback@yourdomain.com
FEEDBACK_NOTIFY_EMAIL=you@yourdomain.com
